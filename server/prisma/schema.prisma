generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Card {
  id        String   @id @default(uuid())
  title     String
  status    Status
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Status {
  todo
  in_progress
  done
}
